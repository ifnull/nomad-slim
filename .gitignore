# Downloaded content and runtime state — keep the directories, not their contents.
data/*
!data/zim/
!data/maps/
!data/kolibri/
!data/**/.gitkeep

data/zim/*
!data/zim/.gitkeep

data/maps/*
!data/maps/.gitkeep

data/kolibri/*
!data/kolibri/.gitkeep

# Downloaded basemap glyphs/sprites + style (from fetch-basemap-assets.sh).
data/basemaps-assets/
# Legacy location from earlier installs — safe to leave ignored.
data/nomad-base-styles.json

# Self-signed certs (from scripts/generate-cert.sh or container fallback).
data/certs/
